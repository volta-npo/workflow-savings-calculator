{
  "name": "@volta-oss/workflow-savings-calculator",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "Estimate whether an automation is actually worth building before a student pod spends time on it.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "test:python": "PYTHONPATH=backend/python python3 -m unittest discover -s backend/python/tests",
    "test:backend": "npm run test:python",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/workflow-savings-calculator:local .",
    "docker:run": "docker compose up --build",
    "serve:python": "PYTHONPATH=backend/python python3 -m workflow_savings_calculator_backend.server"
  },
  "keywords": [
    "ai-automation",
    "digital-equity",
    "local-first",
    "oss",
    "v3-production",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/workflow-savings-calculator.git"
  },
  "homepage": "https://volta-npo.github.io/workflow-savings-calculator/",
  "bugs": {
    "url": "https://github.com/volta-npo/workflow-savings-calculator/issues"
  },
  "author": "Volta OSS Division <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
}
